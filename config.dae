global{
    log_level: info
    wan_interface: auto
    lan_interface: docker0
    auto_config_kernel_parameter: true
    allow_insecure: true
}
dns {
    upstream {
        googledns: 'tcp+udp://dns.google:53'
    }
    routing {
        request {
            fallback: googledns
        }
    }
}

group {
    my_group{
        policy: min
    }
}
routing {
    pname(NetworkManager) -> direct
    pname(agent) -> direct            #komari监控放行，如果代理后IP地区显示不一样强迫症可加，不然去掉就行
    dip(geoip:cloudflare) -> my_group            #代理cloudflare的IP
    dip(geoip:fastly) -> my_group            #代理fastly的IP
    # dip(
    #     这里输入“,”隔开IP，cloudflare和fastly可不用填写            #dae代理组内的IP
    # ) -> my_group

    fallback: direct
}
node{
    # 在下面填入你的节点链接。
    free1:'vless://1a25f8ad-cad2-4e93-b5bf-34e42bcac02a@proxyip.us.cmliussss.net:443?encryption=none&security=tls&sni=sni.111000.indevs.in&fp=firefox&type=ws&host=sni.111000.indevs.in&path=%2F#00'
}

subscription {
